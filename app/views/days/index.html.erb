<h1>Training Days</h1>
 
<table>
  <tr>
    <th>Title</th>
    <th>Text</th>
    <th colspan="2"></th>
  </tr>
 
  <% @days.each do |day| %>
    <tr>
      <td><%= day.title %></td>
      <td><%= day.text %></td>
    <td><%= link_to '| Show', day_path(day) %></td>
    <td><%= link_to '| Edit', edit_day_path(day) %></td>
    <td><%= link_to '| Delete |', day_path(day),
                    method: :delete, data: { confirm: 'Are you sure?' } %></td>
    </tr>
  <% end %>
</table>

<br><br>

<%= link_to '| New day |', new_day_path %>
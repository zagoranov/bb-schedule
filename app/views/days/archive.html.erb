<h3><%= t :archive %></h3>
 
<table class="table table-striped">
  <thead>
  <tr>
    <th><%= t :title%></th>
    <th><%= t :description%></th>
    <th><%= t :actions%></th>
  </tr>
  </thead>
  <tbody>
  <% @archive_days.each do |day| %> 
    <tr>
    <td><%= link_to day.title, day %></td>
    <td><%= day.text %></td>
    <td><%= button_to(t(:restore), unarchive_day_path(day), method: :post, :class => 'btn btn-primary')  %> </td>
    <td><%= button_to(t(:destroy), day, 
             method: :delete, data: { confirm: t(:confirm) }, :class => 'btn btn-mini btn-danger')  %> </td>
    </tr>
  <% end %>
 </tbody>
</table>
<% if @archive_days.size == 0 %>
  <em><%= t :empty %></em>
<% else %>  
<br><br>
<br><br>
<%= link_to t(:kill_all), emptyarchive_days_path, :method => "post", data: { confirm: t(:confirm) }, :class => 'btn btn-mini btn-danger' %> 
<% end %>

<br><br>

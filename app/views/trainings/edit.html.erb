<p><h3><%= t :training%></h3></p>

<br>

<%= form_for([@day, @training], remote: true) do |f| %>
  <p>
    <strong><%= t :body_weight%></strong><br>
    <%= f.text_field :weight %>
  </p>
  <p>
    <strong><%= t :today_tr_desc%></strong><br>
    <%= f.text_area :info, :size => "50x3" %>
  </p>
  <p>
    <%= f.submit t(:edit), :class => 'btn btn-large btn-primary' %>
  </p>
<% end %>

<br>

<h4><%= t :exercises%></h4>
<br>

<div id="trex_table">
  <%= render "trexers_list" %>
</div>

<br><br>

<h4><%= t :add_exercise %></h4>
<%= render "trexercises/trexercise" %>  

<br><br><br>

<%= button_to(t(:fbshare), "#", :id => 'fbshare-link', :class => 'btn btn-mini') %>
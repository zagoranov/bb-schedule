<p><h3>Edit Training</h3></p>

<br><br>

<p><strong>Exercises:</strong></p>

<table class="table table-striped">
  <thead>
  <tr>
    <th>Title</th>
    <th>Reps</th>
    <th>Max Weight</th>
    <th>Actions</th>
  </tr>
  </thead>
  <tbody>
  <% @training.trexercises.each do |trex| %> 
  <tr>
  <td><%= trex.title %></td>
  <td><%= trex.reps %></td>
  <td><%= trex.maxweight %></td>
  <td><%= button_to('Change', edit_trexercise_path(trex), :method => "get", :class => 'btn btn-primary') %></td>
  </tr>
  <% end %>
 </tbody>
</table>

<br><br>

<%= form_for ([@day, @training]) do |f| %>
  <p>
    <strong>Today Body Weight</strong><br>
    <%= f.text_field :weight %>
  </p>
  <p>
    <strong>Today Training`s Description</strong><br>
    <%= f.text_area :info %>
  </p>
  <p>
    <%= f.submit %>
  </p>
<% end %>


<br><br>

<%= button_to('Back to Schedule', days_path, :method => "get", :class => 'btn btn-primary') %>
<h3>New Training Exercise</h3>

<br><br>

<%= form_for ([@trexercise]) do |f| %>
  <p>
    <strong>Exercise</strong><br>
    <%= f.text_field :title %>
  </p>
  <p>
    <strong>Reps</strong><br>
    <%= f.text_area :reps %>
  </p>
  <p>
    <strong>Max Weight</strong><br>
    <%= f.text_area :maxweight %>
  </p>
  <p>
    <%= f.submit "Save Exercise" %>
  </p>
<% end %>
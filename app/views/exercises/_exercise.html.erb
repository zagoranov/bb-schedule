  <tr>
  <td><%= exercise.title %></td>
  <td><%= exercise.reps %></td>
  <td><%= exercise.maxweight %></td>
  <td><%= button_to(t(:up), up_exercise_path(exercise), :method => "get", :class => 'btn btn-mini')  %> </td>
  <td><%= button_to(t(:down), down_exercise_path(exercise), :method => "get", :class => 'btn btn-mini')  %> </td>
  <td><%= button_to(t(:destroy), [exercise.day, exercise], 
             method: :delete, 
             data: { confirm: t(:confirm) }, :class => 'btn btn-mini btn-danger')  %> </td>
</tr>

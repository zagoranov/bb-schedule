<h4><%= t(:wall) %></h4>

  <table class="table table-striped">
  <tbody>
    <tr>
    <%= form_for([@user, @user.given_comments.build], remote: true) do |f| %>  
    <td><%= t :leave_comment %></td>
    <td><%= f.text_area :comment, :size => "40x2" %></td>
    <td><%= f.hidden_field :user_id, :value => @user.id %>  <%= f.hidden_field :commenter_id, :value => @current_user.id %>
      <%= f.submit t(:send), :class => 'btn btn-mini' %> </td>
    <% end %>   
    <tr>
     
  <% for comment in @user.received_comments.order('created_at DESC') %>
    <tr>       
      <td><strong><%= link_to comment.commenter.username, comment.commenter %></strong><br><%= comment.created_at.strftime("%d.%m.%Y %H:%M")%></td>
      <td><%= comment.comment %></td>
   <% if @user == current_user %>      
      <td><%= link_to t(:destroy), user_profilecomment_path(@user, comment), :method => :delete, remote: true, :class => 'btn btn-mini btn-danger' %></td>
   <% end %>
  </tr> 
<% end %>
</tbody>
</table>

<% if @user == current_user %>
         <h4> <%= t(:you) %></h4>
<% end %>

<div id ="prof_details">
  <%= render 'profile_part' %>
</div>

<br><br>

<% if @user != current_user %>
  <h4><%= t(:activity) %></h4>
  <table class="table table-striped">
  <thead>
  <tr>
    <th><%= t :date_time %></th>
    <th><%= t :title %></th>
    <th><%= t :body_weight %></th>    
   </tr>
   </thead>
  <tbody>
  <% for tr in Training.joins(:day).where('user_id in (?)', @user).order('created_at DESC').limit(10) %>
    <tr>       
      <td><%= tr.created_at.strftime("%d.%m.%Y %H:%M")%></td>
      <td>"<%= tr.day.title %>"</td>
      <td><%= tr.weight %></td>
    </tr>       
  <% end %>
  </tbody>
  </table>
<% end %>


<br><br>

<h4><%= t(:wall) %></h4>
<br>
    <%= form_for([@user, @user.given_comments.build], remote: true) do |f| %>  
    <%= f.text_area :comment, placeholder: t(:leave_comment), :size => "50x2" %><br>
    <%= f.hidden_field :user_id, :value => @user.id %>  <%= f.hidden_field :commenter_id, :value => @current_user.id %>
      <%= f.submit t(:send), :class => 'btn btn-mini' %>
<% end %>
<br><br>

<div id ="wallochka">
  <%= render 'comments_part' %>
</div>

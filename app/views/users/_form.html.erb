<%= form_for @user do |f| %>

  <p>
    <%= t :username %><br />
    <%= f.text_field :username %>
  </p>
  <p>
    <%= t :email %><br />
    <%= f.text_field :email %>
  </p>
  <p>
    <%= t :password %><br />
    <%= f.password_field :password %>
  </p>
  <p>
    <%= t :password_confirmation %><br />
    <%= f.password_field :password_confirmation %>
  </p>
  <p class="button"><%= f.submit t(:save), :class => 'btn btn-large btn-primary' %></p>
<% end %>
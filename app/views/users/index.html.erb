<h3><%= t(:uusers)%></h3>

<br><br>

<%= form_tag(users_path, :method => "get", id: "search-form") do %>
  <%= text_field_tag :search, params[:search], placeholder: t(:search_u) %>
  <%= submit_tag t(:search), :name => nil, :class => 'btn btn-mini' %>
<% end %>

<br><br>

<table class="table table-striped">
<tbody>
<% for user in @users %>
<%if user != current_user %>
    <tr>
      <td><strong><%= link_to user.username, user %></strong></td> 
      <td><%= @fr = current_user.friendships.where('friend_id = ?', user.id).first
         if @fr
		  link_to t(:fr_remov), @fr, :method => :delete, :class => 'btn btn-mini btn-danger'
		else
	      link_to t(:fr_add), friendships_path(:friend_id => user), :method => :post, :class => 'btn btn-primary' 
        end
      %></td> 
    </tr>
   <%end %>
 <% end %>
</tbody>
</table>